{
  "$schema": "./schemas/package.schema.json",
  "name": "backup",
  "template": "backup",
  "templateVersion": "0.1.0",
  "configuration": {},
  "deployments": [
    {
      "name": "prod",
      "awsRegion": "us-west-2",
      "awsUser": "goldstack-dev",
      "configuration": {
        "schedule": "cron(15 * * * ? *)",
        "retentionDays": 30,
        "centralBackupVaultArn": "arn:aws:backup:us-east-1:238391222420:backup-vault:GoldstackCentral"
      },
      "tfStateKey": "backup-prod.tfstate",
      "tfVersion": "1.14.7"
    }
  ]
}
