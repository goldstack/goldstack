{
  "name": "@goldstack/backup",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Max Rohde",
  "sideEffects": false,
  "scripts": {
    "build": "yarn clean && yarn compile",
    "clean": "rimraf ./dist",
    "clean-terraform": "rimraf ./infra/aws/.terraform",
    "cleanup-vault": "yarn template cleanup-vault",
    "compile": "tsc -p tsconfig.json",
    "compile-watch": "tsc -p tsconfig.json --watch",
    "configure-from-central": "ts-node --swc scripts/configure-from-central.ts",
    "coverage": "jest --collect-coverage --passWithNoTests --config=./jest.config.js --runInBand",
    "infra": "yarn template infra",
    "template": "yarn template-ts",
    "template-ts": "ts-node --swc scripts/template.ts",
    "test": "echo 'No tests'"
  },
  "dependencies": {
    "@goldstack/template-backup": "0.1.11"
  },
  "devDependencies": {
    "@goldstack/template-backup-cli": "0.1.11",
    "@swc/core": "^1.15.8",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "jest": "^30.2.0",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
